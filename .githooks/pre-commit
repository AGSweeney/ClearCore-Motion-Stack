#!/usr/bin/env sh
set -eu

if ! command -v clang-format >/dev/null 2>&1; then
  echo "ERROR: clang-format is required but not found in PATH."
  echo "Install clang-format, then re-run the commit."
  exit 1
fi

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

needs_check=0
failed=0

for file in $staged_files; do
  case "$file" in
    *.c|*.cc|*.cpp|*.cxx|*.h|*.hh|*.hpp|*.hxx)
      needs_check=1
      if [ -f "$file" ]; then
        if ! clang-format --dry-run --Werror --style=file "$file" >/dev/null 2>&1; then
          echo "Formatting mismatch: $file"
          failed=1
        fi
      fi
      ;;
  esac
done

if [ "$needs_check" -eq 0 ]; then
  exit 0
fi

if [ "$failed" -ne 0 ]; then
  echo ""
  echo "Commit blocked: staged C/C++ files are not clang-formatted."
  echo "Run clang-format -i on the files above, then git add and retry."
  exit 1
fi

exit 0
